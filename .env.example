# Path to trained YOLO weights. Relative paths resolve from the project root.
SENTINEX_MODEL=runs/sentinex/max_train/weights/best.pt

# Lower confidence improves recall for screening; raise it to reduce false positives.
SENTINEX_CONF=0.15
SENTINEX_IOU=0.45
SENTINEX_IMGSZ=640

# 0 uses the fast deterministic Bayesian posterior. Set >0 for PyMC sampling.
SENTINEX_MCMC_SAMPLES=0

# Test-time augmentation improves recall but slows inference.
SENTINEX_TTA=false
SENTINEX_MAX_UPLOAD_MB=15
